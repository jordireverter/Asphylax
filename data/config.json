{
  "max_yara_file_size_mb": 10,
  "heuristics": {
    "enabled": true,
    "base64_min_length": 40,
    "entropy_threshold": 6.0,
    "confidence": {
      "double_extension": 40,
      "base64": 40,
      "url": 30,
      "combination": 60,
      "high_combination": 70,
      "powershell_encoded": 60,
      "suspicious_command": 50,
      "download_execute": 70
    }
  },
  "pe_analysis": {
    "enabled": true,
    "confidence": {
      "suspicious_import": 30,
      "process_injection": 80,
      "networking": 15,
      "packer": 70
    }
  },
  "monitoring": {
    "enabled": true
  },
  "exclusions": {
    "paths": [
      "C:/Windows",
      "C:/Program Files",
      "C:/Program Files (x86)",
      "C:/Users/jordi/AppData"
    ],
    "extensions": [
      ".tmp",
      ".log",
      ".lock",
      ".part",
      ".crdownload",
      ".swp"
    ]
  },
  "ui": {
    "theme": "system"
  },
  "auto_quarantine": {
    "enabled": true,
    "minimum_classification": "malware"
  },

  "quick_scan": {
  "max_file_size_mb": 20,

  "extensions": [
    ".exe",
    ".dll",
    ".scr",
    ".bat",
    ".cmd",
    ".ps1",
    ".js",
    ".vbs",
    ".jar",
    ".msi",
    ".hta",
    ".docm",
    ".xlsm"
  ]
}
}