  "entries": [
    {
      "id": "pattern:powershell-encoded-command",
      "name": "Suspicious PowerShell Encoded Command",
      "description": "Detecta PowerShell amb execució codificada.",
      "category": "script_execution",
      "pattern_type": "regex",
      "pattern": "powershell(\\.exe)?\\s+.*(-enc|-encodedcommand)",
      "severity": "high",
      "confidence": 80,
      "case_sensitive": false,
      "enabled": true
    },
    {
      "id": "pattern:cmd-hidden-execution",
      "name": "Suspicious Hidden CMD Execution",
      "description": "Detecta execució sospitosa de cmd amb paràmetres habituals.",
      "category": "script_execution",
      "pattern_type": "regex",
      "pattern": "cmd(\\.exe)?\\s+.*(/c|/k)",
      "severity": "medium",
      "confidence": 60,
      "case_sensitive": false,
      "enabled": true
    },
    {
      "id": "pattern:download-execute",
      "name": "Download And Execute Pattern",
      "description": "Detecta combinacions típiques de descàrrega i execució.",
      "category": "download_execute",
      "pattern_type": "regex",
      "pattern": "(wget|curl|invoke-webrequest|iwr).*(http|https)",
      "severity": "medium",
      "confidence": 65,
      "case_sensitive": false,
      "enabled": true
    },
    {
      "id": "pattern:mimikatz",
      "name": "Mimikatz Keyword",
      "description": "Detecta una cadena associada a robatori de credencials.",
      "category": "credential_theft",
      "pattern_type": "literal",
      "pattern": "mimikatz",
      "severity": "high",
      "confidence": 85,
      "case_sensitive": false,
      "enabled": true
    },
    {
      "id": "pattern:meterpreter",
      "name": "Meterpreter Keyword",
      "description": "Detecta una cadena associada a Meterpreter.",
      "category": "post_exploitation",
      "pattern_type": "literal",
      "pattern": "meterpreter",
      "severity": "high",
      "confidence": 80,
      "case_sensitive": false,
      "enabled": true
    },
    {
      "id": "pattern:ransomware-extension",
      "name": "Ransomware Extension Pattern",
      "description": "Detecta extensions habituals en fitxers xifrats.",
      "category": "ransomware",
      "pattern_type": "regex",
      "pattern": "\\.(locked|encrypted|crypt|crypted|enc)$",
      "severity": "medium",
      "confidence": 55,
      "case_sensitive": false,
      "enabled": true
    }
  ]
}